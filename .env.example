# ─────────────────────────────────────────────────────────────
# Blossom Natural Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# MongoDB Connection String
# Local:        mongodb://localhost:27017/blossom_natural
# MongoDB Atlas: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/blossom_natural?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/blossom_natural

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# JWT Secret (for future admin auth)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin Credentials (used by create-admin script — run once)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here

# WhatsApp Business Number (country code + number, no + or spaces)
WHATSAPP_NUMBER=2348000000000

# Business Bank Details (displayed at checkout)
BANK_NAME="First Bank Nigeria"
BANK_ACCOUNT_NAME="Blossom Natural Ltd"
BANK_ACCOUNT_NUMBER="0000000000"

# Cloudinary — Image Storage
# Sign up free at https://cloudinary.com → Dashboard → copy these values
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
